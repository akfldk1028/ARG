# Marketing Agent Environment Variables
# Copy to .env and fill in values

# Claude Code (required)
# ANTHROPIC_API_KEY=sk-ant-...

# Web Search (used by tools.py web-search)
# BRAVE_SEARCH_API_KEY=

# Social Media APIs (optional)
# TWITTER_BEARER_TOKEN=
# LINKEDIN_ACCESS_TOKEN=

# CMS Integration (optional)
# GHOST_API_KEY=
# GHOST_API_URL=

# Analytics (optional)
# POSTHOG_API_KEY=
# POSTHOG_PROJECT_ID=

# Notifications (optional)
# SLACK_WEBHOOK_URL=

# SEO APIs (optional)
# AHREFS_API_KEY=
# GOOGLE_SEARCH_CONSOLE_CREDENTIALS=

# A2A Server
MARKETING_AGENT_HOST=127.0.0.1
MARKETING_AGENT_PORT=9020
